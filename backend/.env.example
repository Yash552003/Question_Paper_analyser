# Backend Configuration
# Copy this file to .env and fill in the values

# Your Google Gemini API Key (from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_api_key_here

# Allowed origins for CORS (comma-separated)
# For local development: http://localhost:3000,http://192.168.1.100:3000
# For production: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://192.168.56.1:3000,http://10.0.2.2:3000

# Backend host and port
HOST=0.0.0.0
PORT=8000
